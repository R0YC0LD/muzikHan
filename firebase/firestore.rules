rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Yardımcı Fonksiyonlar
    function isSignedIn() { return request.auth != null; }
    function getUserRole() { 
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role : 'user'; 
    }
    function isAdmin() { return getUserRole() == 'admin'; }
    function isProducer() { return getUserRole() == 'producer'; }
    function isArtist() { return getUserRole() == 'artist'; }
    function isOwner(uid) { return request.auth.uid == uid; }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(uid) && (
        !('isApproved' in request.resource.data) || request.resource.data.isApproved == false
      );
      allow update: if isSignedIn() && (
        (isOwner(uid) && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['isApproved', 'role']))) || 
        isAdmin()
      );
      allow delete: if isSignedIn() && isAdmin();
    }

    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isAdmin();
      allow update, delete: if isSignedIn() && (isAdmin() || isOwner(resource.data.ownerId));
    }

    match /demos/{demoId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && (isAdmin() || isProducer());
      allow delete: if isSignedIn() && isAdmin();
    }

    match /releases/{releaseId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (isAdmin() || isArtist() || isProducer());
      allow update, delete: if isSignedIn() && isAdmin();
    }

    match /beats/{beatId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && (isAdmin() || isProducer());
      allow delete: if isSignedIn() && (isAdmin() || isOwner(resource.data.ownerId));
    }
    
    match /presets/{presetId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && (isAdmin() || isProducer());
      allow delete: if isSignedIn() && (isAdmin() || isOwner(resource.data.ownerId));
    }

    match /stems/{stemId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && (isAdmin() || isProducer());
      allow delete: if isSignedIn() && (isAdmin() || isOwner(resource.data.ownerId));
    }

    match /notifications/{uid}/user_notifications/{docId} {
      allow read, delete: if isSignedIn() && isOwner(uid);
      allow create, update: if isSignedIn();
    }
    
    match /chats/{chatId} {
      allow read, write: if isSignedIn() && (
        chatId.matches('.*' + request.auth.uid + '.*') ||
        (resource != null && request.auth.uid in resource.data.participants) ||
        (request.resource != null && request.auth.uid in request.resource.data.participants)
      );
    }

    match /chats/{chatId}/messages/{msgId} {
      allow read, write: if isSignedIn() && (
        chatId.matches('.*' + request.auth.uid + '.*') ||
        (get(/databases/$(database)/documents/chats/$(chatId)).data != null && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants)
      );
    }
    
    match /friends/{uid}/list/{friendId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isOwner(uid);
    }

    match /tasks/{uid}/assigned/{taskId} {
      allow read: if isSignedIn() && (isOwner(uid) || isAdmin());
      allow create, update: if isSignedIn() && isAdmin();
      allow delete: if isSignedIn() && (isOwner(uid) || isAdmin());
    }
  }
}
